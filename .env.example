# StepFun API Key。自动生成无字幕视频文稿时必填。
# 获取地址：https://platform.stepfun.com/
STEP_API_KEY=

# StepAudio 2.5 ASR 接口地址。默认使用官方公网接口，一般不需要修改。
# STEP_AUDIO_ASR_URL=https://api.stepfun.com/v1/audio/asr/sse

# 单个视频自动转写的最长时长，单位：分钟。默认 30 分钟。
# STEP_ASR_MAX_DURATION_MINUTES=30

# StepAudio 单次请求音频大小安全上限，单位：MB。默认 39 MB，可调低；超过 39 会被按 39 处理。
# 超过该大小后会自动分段转写并合并文稿，避免触发 StepAudio 40 MiB 服务端限制。
# STEP_ASR_MAX_REQUEST_FILE_MB=39

# 同时运行的 STT 任务数。当前本地 MVP 建议保持 1，避免占用过多带宽和费用。
# STEP_ASR_MAX_CONCURRENT_TASKS=1

# 内存中转写任务状态保留时间，单位：秒。默认 86400 秒，即 24 小时。
# STEP_ASR_TASK_TTL_SECONDS=86400

# DeepSeek API Key。AI 视频总结必填。
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# DeepSeek OpenAI-compatible base URL。一般不需要修改。
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# AI 总结模型。默认使用 V4 Flash。
# DEEPSEEK_MODEL=deepseek-v4-flash

# 是否开启 DeepSeek 思考模式。默认 false；可设置为 true/false。
# DEEPSEEK_THINKING_ENABLED=false

# DeepSeek 请求超时，单位秒。长视频总结可能需要较长连接。
# DEEPSEEK_REQUEST_TIMEOUT_SECONDS=900

# AI 总结问答内存会话 TTL，单位秒。默认 86400 秒，即 24 小时。
# AI_SUMMARY_SESSION_TTL_SECONDS=86400

# 单次自定义总结提示词最大字符数。
# AI_SUMMARY_CUSTOM_PROMPT_MAX_CHARS=2000
