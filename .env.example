# StepFun API Key。自动生成无字幕视频文稿时必填。
# 获取地址：https://platform.stepfun.com/
STEP_API_KEY=

# StepAudio 2.5 ASR 接口地址。默认使用官方公网接口，一般不需要修改。
# STEP_AUDIO_ASR_URL=https://api.stepfun.com/v1/audio/asr/sse

# 单个视频自动转写的最长时长，单位：分钟。默认 30 分钟。
# STEP_ASR_MAX_DURATION_MINUTES=30

# 单个转写音频文件大小上限，单位：MB。默认 64 MB。
# STEP_ASR_MAX_AUDIO_FILE_MB=64

# 同时运行的 STT 任务数。当前本地 MVP 建议保持 1，避免占用过多带宽和费用。
# STEP_ASR_MAX_CONCURRENT_TASKS=1

# 内存中转写任务状态保留时间，单位：秒。默认 86400 秒，即 24 小时。
# STEP_ASR_TASK_TTL_SECONDS=86400
